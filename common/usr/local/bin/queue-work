#!/bin/sh

echo '
-------------------------------------
🚀 Laravel queue worker
-------------------------------------
🛠️ Configuration
• MAX_JOBS:      '"$QUEUE_MAX_JOBS"'
• SLEEP:         '"$QUEUE_SLEEP"'
• REST:          '"$QUEUE_REST"'
• TIMEOUT:       '"$QUEUE_TIMEOUT"'
• TRIES:         '"$QUEUE_TRIES"'
'

artisan queue:work \
    --max-jobs $QUEUE_MAX_JOBS \
    --sleep $QUEUE_SLEEP \
    --rest $QUEUE_REST \
    --timeout $QUEUE_TIMEOUT \
    --tries $QUEUE_TRIES \
    --force
